---
import Layout from "@layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

// 1. Fonction obligatoire dans Astro pour générer toutes les URL des projets
export async function getStaticPaths() {
  const allProjects = await getCollection("projects");

  const sortedProjects = allProjects.sort(
    (a, b) => a.data.order - b.data.order,
  );

  return sortedProjects.map((project, index) => {
    const prevProject = index === 0 ? null : sortedProjects[index - 1];
    const nextProject =
      index === sortedProjects.length - 1 ? null : sortedProjects[index + 1];

    return {
      params: { slug: project.slug },
      props: { project, prevProject, nextProject },
    };
  });
}

// 2. On récupère le projet actuel et son contenu texte
const { project, prevProject, nextProject } = Astro.props;
const { Content } = await project.render();

const gallery = project.data.gallery || [];
---

<Layout title={`Taaral - ${project.data.title}`}>
  {/* EN-TÊTE DU PROJET */}
  <section class="bg-transparent px-4 pb-16 text-primary-dark md:px-12">
    <div class="mx-auto max-w-[1920px]">
      <h1 class="mb-6 font-display text-5xl md:text-7xl lg:text-8xl">
        {project.data.title}
      </h1>
      <p class="font-sans text-xs uppercase tracking-[0.2em] text-[#C06C61]">
        {project.data.location}
      </p>
    </div>
  </section>

  {/* IMAGE PRINCIPALE GÉANTE */}
  <section class="mb-24 w-full px-4 md:px-12">
    <div
      class="mx-auto aspect-video w-full max-w-[1920px] overflow-hidden bg-gray-100"
    >
      <Image
        src={project.data.image}
        alt={project.data.title}
        class="size-full object-cover"
        transition:name={`image-${project.slug}`}
      />
    </div>
  </section>

  {/* DESCRIPTION DU PROJET */}
  <section class="mb-32 w-full px-4 md:px-12">
    <div
      class="prose prose-gray mx-auto max-w-3xl prose-p:text-lg prose-p:font-light prose-p:leading-relaxed prose-p:text-primary"
    >
      <Content />
    </div>
  </section>

  {/* LA FAMEUSE GALERIE PHOTOS */}
  {
    gallery.length > 0 ? (
      <section class="w-full px-4 pb-32 md:px-12">
        <div class="mx-auto max-w-[1920px]">
          <h2 class="mb-12 border-b border-accent pb-4 font-sans text-[10px] font-bold uppercase tracking-[0.2em] text-accent">
            Project Gallery
          </h2>

          {/* Grille dynamique selon le nombre de photos */}
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-12">
            {gallery.map((image) => {
              return (
                <div class="aspect-square w-full overflow-hidden bg-gray-100">
                  <Image
                    src={image}
                    alt={`${project.data.title} detail`}
                    class="size-full object-cover"
                  />
                </div>
              );
            })}
          </div>
        </div>
      </section>
    ) : (
      <section class="w-full px-4 pb-32 md:px-12">
        <div class="flex w-full flex-col items-center justify-center border border-dashed border-gray-300 py-32 text-center">
          <span class="material-symbols-outlined mb-4 text-4xl text-gray-300">
            photo_camera
          </span>
          <p class="font-sans text-[10px] uppercase tracking-[0.2em] text-gray-400 md:text-xs">
            D'autres photos de ce projet seront bientôt disponibles
          </p>
        </div>
      </section>
    )
  }

  {/* 🚀 NAVIGATION PRÉCÉDENT / SUIVANT */}
  {
    (prevProject || nextProject) && (
      <section class="w-full border-t border-gray-200">
        <div class="mx-auto flex max-w-[1920px] flex-col divide-y divide-gray-200 md:flex-row md:divide-x md:divide-y-0">
          {/* BOUTON PRÉCÉDENT (S'affiche uniquement s'il existe) */}
          {prevProject && (
            <a
              href={`/projects/${prevProject.slug}`}
              class={`group flex w-full flex-col items-start bg-transparent p-8 transition-colors hover:bg-primary-dark hover:text-white md:p-16 ${nextProject ? "md:w-1/2" : ""}`}
            >
              <span class="mb-4 text-[10px] uppercase tracking-widest text-primary transition-colors group-hover:text-primary/90">
                Previous Project
              </span>
              <span class="font-display text-3xl text-primary-dark transition-colors group-hover:text-accent md:text-5xl">
                {prevProject.data.title}
              </span>
            </a>
          )}

          {/* BOUTON SUIVANT (S'affiche uniquement s'il existe) */}
          {nextProject && (
            <a
              href={`/projects/${nextProject.slug}`}
              class={`group flex w-full flex-col items-end bg-transparent p-8 text-right transition-colors hover:bg-primary-dark hover:text-white md:p-16 ${prevProject ? "md:w-1/2" : ""}`}
            >
              <span class="mb-4 text-[10px] uppercase tracking-widest text-primary transition-colors group-hover:text-primary/90">
                Next Project
              </span>
              <span class="font-display text-3xl text-primary-dark transition-colors group-hover:text-accent md:text-5xl">
                {nextProject.data.title}
              </span>
            </a>
          )}
        </div>
      </section>
    )
  }
</Layout>
