---
import Layout from "@layouts/Layout.astro";
import { getEntry } from "astro:content";

// On récupère les données depuis Keystatic
const legalEntry = await getEntry("legal", "data");
const { Content } = legalEntry
  ? await legalEntry.render()
  : { Content: () => null };

// On récupère les titres (avec des valeurs par défaut si vide)
const surtitle = legalEntry?.data.surtitle || "Informations légales";
const title = legalEntry?.data.title || "Mentions Légales";
const titleAccent = legalEntry?.data.titleAccent || "& Confidentialité";
---

<Layout title={`Taaral - ${title}`}>
  <section
    class="min-h-screen w-full bg-transparent px-4 pb-32 pt-40 text-black md:px-12 md:pt-48"
  >
    <div class="mx-auto max-w-4xl">
      {/* 1. L'EN-TÊTE GÉRÉ PAR KEYSTATIC */}
      <div class="mb-16 md:mb-24">
        <span
          class="mb-6 block text-[10px] font-bold uppercase tracking-[0.2em] text-[#C06C61]"
        >
          {surtitle}
        </span>
        <h1 class="font-display text-5xl leading-tight text-black md:text-7xl">
          {title}
          <br />
          <span class="font-light italic text-[#C06C61]">{titleAccent}</span>
        </h1>
      </div>

      {/* 2. LE CONTENU MARKDOWN STYLISÉ COMME TON DESIGN */}
      {
        /* Les classes "prose" forcent le HTML de Keystatic à utiliser tes styles exacts */
      }
      <div
        class="prose max-w-none
               prose-headings:font-display prose-headings:font-normal prose-headings:text-black
               prose-h2:mb-6 prose-h2:mt-16 prose-h2:text-3xl prose-p:text-sm
               prose-p:font-light prose-p:leading-relaxed prose-p:text-black prose-a:text-[#C06C61] prose-a:no-underline
               prose-a:transition-opacity hover:prose-a:opacity-70 prose-strong:font-bold prose-strong:text-black
               md:prose-h2:text-4xl md:prose-p:text-base"
      >
        {
          legalEntry ? (
            <Content />
          ) : (
            <p>Veuillez rédiger ce contenu dans Keystatic.</p>
          )
        }
      </div>
    </div>
  </section>
</Layout>
