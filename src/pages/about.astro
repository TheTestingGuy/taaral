---
import Layout from "@layouts/Layout.astro";
---

<Layout title="Material Creative - About">
  <div class="mx-auto w-full max-w-[1920px] px-4 pb-20 md:px-12">
    <section
      class="group relative mb-16 mt-8 w-full overflow-hidden md:mb-24 md:mt-12"
    >
      <div
        class="aspect-[16/9] w-full overflow-hidden rounded-sm shadow-2xl md:aspect-[21/9] lg:aspect-[16/8]"
      >
        <img
          alt="Luxurious modern office interior with wooden paneling and burgundy accents"
          class="size-full object-cover transition-transform duration-1000 ease-out group-hover:scale-105"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuDVbqYbs2KUw0ChetVZ3-UKslyI2VmNs_X2TCWeMT2VvGlmYDRL9DqdYx0vnnPTMPpiPE5fSgUZ68uaHQ9NtjfH3ddmryxKdabylsx9shC7EdTdrSw8to-YK_tVH-4pPnHxQq4tJXpcijkQdUtZrgdvVRKaWOL6EV7_aU5Suoe3sfLdbOeB3cKL46v9cIxp920caOEq5oeHjTTsktO5P2QfddZXz-br_LH9aDms00FwVLhd3dqLBWtMT8rK0otIxCD9guKVVLedpR8"
        />
      </div>
    </section>

    <section class="mx-auto mb-32 w-full max-w-5xl px-4">
      <div class="grid grid-cols-1 items-start gap-12 md:grid-cols-12">
        <div class="order-2 mt-12 md:order-1 md:col-span-5 md:mt-0">
          <div class="relative">
            <div
              class="mb-6 aspect-[3/4] overflow-hidden rounded-sm grayscale transition-all duration-700 hover:grayscale-0"
            >
              <img
                alt="Close up of textured design material"
                class="size-full object-cover"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuATjHYa4r-Nq5ZKnBMcqakXlF6poSsy0QLzUOtXa6SDD-kxCpcGQRNjkdihjilPq6gJPUNBOlpv4dUsnkZ1ZxYuTkj5E7khiqv3w5vGUbshGHyeT9Ud-x78vKhLkdRKRT3L2P-b9zfhQ0DGvET34jLbUlF-IbOWzQ67FrjAFL5ZWIhnkMRxtQZTx180P-1OQpm0vkvK9d8Lddqy-5qhEqFdDGBIpO0NnhESTzbvyXHnX6Kt4OXGLIxmM_wZNWDL2kL8QRdBsHjEw7s"
              />
            </div>
            <p class="font-sans text-xs uppercase tracking-widest opacity-60">
              Est. 2014 — Milan, Italy
            </p>
          </div>
        </div>

        <div class="order-1 md:order-2 md:col-span-7">
          <h2
            class="mb-8 font-display text-4xl leading-tight text-accent md:mb-12 md:text-5xl lg:text-6xl"
          >
            We are on a mission to challenge the status quo...
          </h2>
          <div
            class="max-w-prose space-y-6 font-sans text-lg font-light leading-relaxed opacity-90 md:text-xl"
          >
            <p>
              To an interior of Interior design devoyet experience nation of
              purely and dbose an ext blaters. We believe that spaces should be
              more than just functional containers; they should be evocative
              narratives that speak to the soul.
            </p>
            <p>
              Our philosophy is rooted in the tactile and the timeless. We strip
              away the unnecessary to reveal the raw beauty of natural
              materials, crafting environments that age gracefully and tell a
              story of their own.
            </p>
          </div>

          <div
            class="mt-12 flex flex-col items-start justify-between gap-8 border-t border-accent/20 pt-8 sm:flex-row sm:items-center"
          >
            <div>
              <span
                class="mb-1 block text-xs uppercase tracking-widest opacity-60"
                >Lead Architect</span
              >
              <span class="font-display text-xl">Isabella Rossi</span>
            </div>
            <a
              class="group inline-flex items-center gap-2 text-sm font-medium uppercase tracking-widest text-accent transition-colors hover:text-white"
              href="#"
            >
              Read Full Bio
              <span
                class="material-symbols-outlined text-lg transition-transform group-hover:translate-x-1"
                >arrow_forward</span
              >
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-auto w-full border-t border-accent/30 pt-16">
      <h3
        class="mb-8 truncate font-display text-5xl text-accent/40 md:text-7xl lg:text-8xl"
      >
        More inspiration
      </h3>
    </section>
  </div>
</Layout>
