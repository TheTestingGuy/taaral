---
import { Image } from "astro:assets";
import { getEntry } from "astro:content";

// 1. On récupère les données de Keystatic
const aboutEntry = await getEntry("about", "data");
const { Content } = aboutEntry
  ? await aboutEntry.render()
  : { Content: () => null };

// 2. Variables avec valeurs par défaut (fallback)
const data = aboutEntry?.data || {};
const caption = data.caption || "Est. 2014 — Paris, France";
const surtitle = data.surtitle || "About Us";
// On remplace les sauts de ligne tapés par la cliente par des vraies balises <br/>
const headline = data.headline
  ? data.headline.replace(/\n/g, "<br />")
  : "to challenge the<br />status quo...";
const architectRole = data.architectRole || "Lead Architect";
const architectName = data.architectName || "Isabella Rossi";

// 3. Gestion de l'image (Astuce Astro Assets)
const rawImagePath = data.image;
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/about/*.{jpeg,jpg,png,gif,webp}",
);
const validImagePath = rawImagePath
  ? rawImagePath.replace("../../assets", "/src/assets")
  : null;
const imageExists = validImagePath && images[validImagePath];
---

<section
  id="about"
  data-bg="bg-primary"
  class="w-full bg-transparent px-4 py-24 text-black md:px-12 md:py-32"
>
  <div
    class="mx-auto grid w-full max-w-6xl grid-cols-1 items-start gap-16 md:grid-cols-2 md:gap-24"
  >
    {/* COLONNE GAUCHE */}
    <div class="flex flex-col gap-6">
      <div class="aspect-square w-full max-w-md overflow-hidden bg-gray-100">
        {
          imageExists ? (
            <Image
              src={images[validImagePath]()}
              alt={architectName}
              class="size-full object-cover"
            />
          ) : (
            <div class="flex size-full items-center justify-center bg-gray-200 text-sm text-gray-400">
              Image manquante
            </div>
          )
        }
      </div>
      <p
        class="font-sans text-[9px] uppercase tracking-[0.2em] text-gray-400 md:text-[10px]"
      >
        {caption}
      </p>
    </div>

    {/* COLONNE DROITE */}
    <div class="flex flex-col pt-8">
      <span
        class="mb-6 text-[9px] font-bold uppercase tracking-[0.2em] text-[#C06C61] md:text-[10px]"
      >
        {surtitle}
      </span>

      {
        /* On utilise set:html pour que la balise <br/> s'affiche correctement */
      }
      <h2
        class="mb-10 font-display text-5xl leading-tight text-[#C06C61] md:text-6xl"
        set:html={headline}
      />

      {
        /* Le contenu Markdown (géré par Tailwind Typography pour matcher ton design) */
      }
      <div
        class="prose prose-gray mb-16 max-w-prose prose-p:mb-6 prose-p:text-sm prose-p:font-light prose-p:leading-relaxed prose-p:text-gray-600 md:prose-p:text-base"
      >
        {
          aboutEntry ? (
            <Content />
          ) : (
            <p>Veuillez remplir la section About dans Keystatic.</p>
          )
        }
      </div>

      {/* LE BLOC SIGNATURE */}
      <div class="flex items-end justify-between border-b border-gray-200 pb-4">
        <div>
          <span
            class="mb-2 block text-[9px] uppercase tracking-widest text-gray-400 md:text-[10px]"
          >
            {architectRole}
          </span>
          <span class="font-display text-2xl italic text-black">
            {architectName}
          </span>
        </div>
        <a
          href="/legal"
          class="flex items-center gap-2 text-[9px] font-bold uppercase tracking-[0.2em] text-black transition-opacity hover:opacity-70 md:text-[10px]"
        >
          Read Full Bio <span class="material-symbols-outlined text-sm"
            >arrow_forward</span
          >
        </a>
      </div>
    </div>
  </div>
</section>
