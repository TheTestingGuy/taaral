---
import Footer from "@components/Footer.astro";
import Header from "@components/HeaderNew.astro";
// import Header from "@components/Header.astro";
import Loader from "@components/Loader.astro";

import { ClientRouter } from "astro:transitions";

// Imports des polices locales Fontsource
import "@fontsource/dm-serif-display";
import "@fontsource/inter/300.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/playfair-display/400.css";
import "@fontsource/playfair-display/400-italic.css";
import "@fontsource/playfair-display/500.css";
import "@fontsource/playfair-display/600.css";
import "@fontsource/playfair-display/700.css";

import "material-icons/iconfont/material-icons.css";
import "material-symbols/outlined.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <ClientRouter />
  </head>
  <body
    class="flex min-h-screen flex-col bg-secondary-dark font-body text-primary antialiased transition-colors duration-[800ms] ease-in-out selection:bg-accent selection:text-background-dark"
  >
    <Loader />

    <Header />

    <main class="flex w-full grow flex-col items-center pt-80 md:pt-96">
      <slot />
    </main>

    <Footer />

    <script>
      document.addEventListener("astro:page-load", () => {
        let currentBgClass = "";
        const sections = document.querySelectorAll("[data-bg]");
        const body = document.body;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const newBgClass = entry.target.getAttribute("data-bg");

                if (newBgClass && newBgClass !== currentBgClass) {
                  if (currentBgClass) {
                    body.classList.remove(...currentBgClass.split(" "));
                  }
                  body.classList.add(...newBgClass.split(" "));
                  currentBgClass = newBgClass;
                }
              }
            });
          },
          {
            rootMargin: "-50% 0px -50% 0px",
          },
        );

        sections.forEach((section) => observer.observe(section));
      });
    </script>
  </body>
</html>

<style is:global>
  /* 1. Ralentir les animations de View Transitions (Morphing et fondu) */
  /* ::view-transition-group(*), */
  /* ::view-transition-old(*), */
  /* ::view-transition-new(*) { */
  /* animation-duration: 0.8s; Règle la durée ici (0.8s donne un bel effet "cinématographique") */
  /* animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1); Une courbe d'accélération très douce (ease-in-out) */
  /* } */

  @font-face {
    font-family: "DigitalGeometric"; /* Le nom que tu veux lui donner */
    src: url("/fonts/digital_geometric_bold.ttf") format("truetype"); /* Le chemin vers ton fichier */
    font-weight: bold; /* Modifie si c'est du gras (bold) etc. */
    font-style: normal;
    font-display: swap; /* Permet d'afficher le texte sans attendre le chargement complet */
  }

  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #2a0f10;
  }
  ::-webkit-scrollbar-thumb {
    background: #ae5e4c;
    border-radius: 4px;
  }
</style>
