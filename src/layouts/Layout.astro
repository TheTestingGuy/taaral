---
// src/layouts/Layout.astro
import Footer from "@components/Footer.astro";
import Header from "@components/Header";

import { ClientRouter } from "astro:transitions";

import ScrollColorObserver from "@components/react/ScrollColorObserver";

// Imports des polices locales Fontsource
import "@fontsource/dm-serif-display";
import "@fontsource/inter/300.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/playfair-display/400.css";
import "@fontsource/playfair-display/400-italic.css";
import "@fontsource/playfair-display/500.css";
import "@fontsource/playfair-display/600.css";
import "@fontsource/playfair-display/700.css";

import "material-icons/iconfont/material-icons.css";
import "material-symbols/outlined.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <ClientRouter />
  </head>
  <body
    class="text-primary font-body antialiased min-h-screen flex flex-col selection:bg-accent selection:text-background-dark transition-colors duration-[800ms] ease-in-out"
  >
    <Header client:load />

    <main class="flex-grow w-full flex flex-col items-center">
      <slot />
    </main>

    <Footer />

    <ScrollColorObserver client:idle />
  </body>
</html>

<style is:global>
  /* 1. Ralentir les animations de View Transitions (Morphing et fondu) */
  /* ::view-transition-group(*), */
  /* ::view-transition-old(*), */
  /* ::view-transition-new(*) { */
  /* animation-duration: 0.8s; Règle la durée ici (0.8s donne un bel effet "cinématographique") */
  /* animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1); Une courbe d'accélération très douce (ease-in-out) */
  /* } */

  @font-face {
    font-family: "DigitalGeometric"; /* Le nom que tu veux lui donner */
    src: url("/fonts/digital_geometric_bold.ttf") format("truetype"); /* Le chemin vers ton fichier */
    font-weight: bold; /* Modifie si c'est du gras (bold) etc. */
    font-style: normal;
    font-display: swap; /* Permet d'afficher le texte sans attendre le chargement complet */
  }

  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #2a0f10;
  }
  ::-webkit-scrollbar-thumb {
    background: #ae5e4c;
    border-radius: 4px;
  }
</style>
