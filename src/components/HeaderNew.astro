<header
  id="main-header"
  class="fixed left-0 top-0 z-50 w-full transform-gpu bg-transparent p-6 text-white transition-all duration-[800ms] ease-in-out md:py-8"
>
  <div class="mx-auto flex w-full max-w-[1920px] items-start justify-between">
    {/* Colonne Gauche */}
    <div class="w-1/3 pt-2">
      <a
        href="/projects"
        class="text-[10px] font-medium uppercase tracking-widest transition-opacity hover:opacity-70 md:text-xs"
        >Projects</a
      >
    </div>

    {/* Colonne Centre : Le conteneur magique */}
    <div class="flex w-1/3 justify-center text-center">
      {
        /* 1. Le "Wrapper" relatif qui dicte la vraie hauteur physique au header */
      }
      <a
        href="/"
        id="logo-wrapper"
        class="group relative h-[90px] w-full transition-all duration-[800ms] ease-in-out md:h-[140px] lg:h-[180px]"
      >
        {
          /* 2. Le texte absolu qui se redimensionne visuellement sans buguer Safari */
        }
        <div
          id="header-title"
          class="absolute left-1/2 top-0 flex origin-top -translate-x-1/2 scale-100 flex-col items-center transition-transform duration-[800ms] ease-in-out will-change-transform"
        >
          {/* whitespace-nowrap force le texte à rester sur une seule ligne */}
          <h1
            class="whitespace-nowrap font-logo text-6xl leading-none tracking-tight text-accent transition-opacity duration-300 group-hover:opacity-80 md:text-8xl lg:text-[9rem]"
          >
            Taaral
          </h1>

          <span
            id="header-subtitle"
            class="mt-2 h-[1em] overflow-hidden font-display text-3xl font-light italic opacity-100 transition-all duration-[800ms] ease-in-out md:text-5xl lg:text-7xl"
          >
            intérieur
          </span>
        </div>
      </a>
    </div>

    {/* Colonne Droite */}
    <div class="flex w-1/3 justify-end gap-4 pt-2 text-right md:gap-8">
      <a
        href="/#about"
        class="text-[10px] font-medium uppercase tracking-widest transition-opacity hover:opacity-70 md:text-xs"
        >About</a
      >
      <a
        href="/#contact"
        class="text-[10px] font-medium uppercase tracking-widest transition-opacity hover:opacity-70 md:text-xs"
        >Contact</a
      >
    </div>
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const header = document.getElementById("main-header");
    const logoWrapper = document.getElementById("logo-wrapper");
    const titleContainer = document.getElementById("header-title");
    const subtitle = document.getElementById("header-subtitle");

    if (!header || !logoWrapper || !titleContainer || !subtitle) return;

    const handleScroll = () => {
      if (window.scrollY > 50) {
        // 1. Fond et padding du header global
        header.classList.add("py-4", "bg-[#351419]", "shadow-lg");
        header.classList.remove("py-6", "md:py-8", "bg-transparent");

        // 2. On réduit la hauteur PHYSIQUE du conteneur (Safari valide)
        logoWrapper.classList.add("h-[40px]", "md:h-[50px]", "lg:h-[60px]");
        logoWrapper.classList.remove(
          "h-[90px]",
          "md:h-[140px]",
          "lg:h-[180px]",
        );

        // 3. On réduit l'échelle VISUELLE du texte (Carte graphique)
        titleContainer.classList.add(
          "scale-[0.5]",
          "md:scale-[0.45]",
          "lg:scale-[0.4]",
        );
        titleContainer.classList.remove("scale-100");

        // 4. On referme la boîte du sous-titre
        subtitle.classList.add("opacity-0", "h-0", "text-[0px]", "mt-0");
        subtitle.classList.remove(
          "opacity-100",
          "h-[1em]",
          "text-3xl",
          "md:text-5xl",
          "lg:text-7xl",
          "mt-2",
        );
      } else {
        // 1. On restaure le header global
        header.classList.remove("py-4", "bg-[#351419]", "shadow-lg");
        header.classList.add("py-6", "md:py-8", "bg-transparent");

        // 2. On restaure la hauteur PHYSIQUE
        logoWrapper.classList.remove("h-[40px]", "md:h-[50px]", "lg:h-[60px]");
        logoWrapper.classList.add("h-[90px]", "md:h-[140px]", "lg:h-[180px]");

        // 3. On restaure l'échelle VISUELLE
        titleContainer.classList.remove(
          "scale-[0.5]",
          "md:scale-[0.45]",
          "lg:scale-[0.4]",
        );
        titleContainer.classList.add("scale-100");

        // 4. On rouvre le sous-titre
        subtitle.classList.remove("opacity-0", "h-0", "text-[0px]", "mt-0");
        subtitle.classList.add(
          "opacity-100",
          "h-[1em]",
          "text-3xl",
          "md:text-5xl",
          "lg:text-7xl",
          "mt-2",
        );
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();
  });
</script>
