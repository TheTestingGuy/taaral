---

---

<header
  id="main-header"
  class="fixed left-0 top-0 z-50 w-full bg-transparent px-6 py-8 text-white transition-all duration-[800ms] ease-in-out md:py-12"
>
  <div class="mx-auto flex w-full max-w-[1920px] items-start justify-between">
    {/* Colonne Gauche */}
    <div class="w-1/3 self-center">
      <a
        href="/projects"
        class="text-[10px] font-medium uppercase tracking-widest transition-opacity hover:opacity-70 md:text-xs"
        >Projects</a
      >
    </div>

    {/* Colonne Centre */}
    <div class="flex w-1/3 justify-center text-center">
      <a href="/" class="group flex flex-col items-center">
        <h1
          id="header-title"
          class="font-logo text-6xl leading-none tracking-tight text-accent transition-all duration-[800ms] ease-in-out group-hover:opacity-80 md:text-8xl lg:text-[9rem]"
        >
          Taaral
        </h1>
        <span
          id="header-subtitle"
          class="mt-2 h-[1em] overflow-hidden font-display text-3xl font-light italic opacity-100 transition-all duration-[800ms] ease-in-out md:text-5xl lg:text-7xl"
        >
          intérieur
        </span>
      </a>
    </div>

    {/* Colonne Droite */}
    <div class="flex w-1/3 justify-end gap-4 self-center text-right md:gap-8">
      <a
        href="/#about"
        class="text-[10px] font-medium uppercase tracking-widest transition-opacity hover:opacity-70 md:text-xs"
        >About</a
      >
      <a
        href="/#contact"
        class="text-[10px] font-medium uppercase tracking-widest transition-opacity hover:opacity-70 md:text-xs"
        >Contact</a
      >
    </div>
  </div>
</header>

<script>
  // On utilise astro:page-load pour que ça marche bien avec les View Transitions
  document.addEventListener("astro:page-load", () => {
    const header = document.getElementById("main-header");
    const title = document.getElementById("header-title");
    const subtitle = document.getElementById("header-subtitle");

    if (!header || !title || !subtitle) return;

    const handleScroll = () => {
      if (window.scrollY > 50) {
        // État scrollé (Petit)
        header.classList.add("py-4", "bg-[#351419]", "shadow-lg");
        header.classList.remove("py-8", "md:py-12", "bg-transparent");

        title.classList.add("text-3xl", "md:text-5xl");
        title.classList.remove("text-6xl", "md:text-8xl", "lg:text-[9rem]");

        subtitle.classList.add("opacity-0", "h-0", "text-[0px]", "mt-0");
        subtitle.classList.remove(
          "opacity-100",
          "h-[1em]",
          "text-3xl",
          "md:text-5xl",
          "lg:text-7xl",
          "mt-2",
        );
      } else {
        // État en haut (Grand)
        header.classList.remove("py-4", "bg-[#351419]", "shadow-lg");
        header.classList.add("py-8", "md:py-12", "bg-transparent");

        title.classList.remove("text-3xl", "md:text-5xl");
        title.classList.add("text-6xl", "md:text-8xl", "lg:text-[9rem]");

        subtitle.classList.remove("opacity-0", "h-0", "text-[0px]", "mt-0");
        subtitle.classList.add(
          "opacity-100",
          "h-[1em]",
          "text-3xl",
          "md:text-5xl",
          "lg:text-7xl",
          "mt-2",
        );
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll(); // Initialisation
  });
</script>
