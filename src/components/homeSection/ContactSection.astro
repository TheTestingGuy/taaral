---
---
<section id="contact" class="w-full max-w-5xl mx-auto border-t border-primary/20 pt-16 md:pt-24 mb-24 md:mb-32">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
    <div>
      <h3 class="font-display text-4xl md:text-6xl text-primary mb-6">Let's work<br/>together.</h3>
      <p class="text-lg font-light opacity-80 mb-8 max-w-md">
        Prêt à transformer votre espace ? Remplissez le formulaire ci-contre ou envoyez-nous un e-mail, nous vous répondrons dans les plus brefs délais.
      </p>
      <p class="text-sm uppercase tracking-widest opacity-60 mb-2">Email</p>
      <a href="mailto:hello@taaral.com" class="font-display text-2xl hover:text-accent transition-colors">hello@taaral.com</a>
    </div>

    <form name="contact" method="POST" data-netlify="true" class="flex flex-col gap-8 mt-4 md:mt-0">
      <input type="hidden" name="form-name" value="contact" />

      <div class="flex flex-col gap-2">
        <label for="name" class="text-xs uppercase tracking-widest opacity-60">Nom complet</label>
        <input type="text" id="name" name="name" required class="bg-transparent border-0 border-b border-primary/30 focus:border-accent focus:ring-0 px-0 py-2 text-primary transition-colors focus:outline-none" />
      </div>

      <div class="flex flex-col gap-2">
        <label for="email" class="text-xs uppercase tracking-widest opacity-60">Adresse e-mail</label>
        <input type="email" id="email" name="email" required class="bg-transparent border-0 border-b border-primary/30 focus:border-accent focus:ring-0 px-0 py-2 text-primary transition-colors focus:outline-none" />
      </div>

      <div class="flex flex-col gap-2">
        <label for="message" class="text-xs uppercase tracking-widest opacity-60">Détails du projet</label>
        <textarea id="message" name="message" rows="4" required class="bg-transparent border-0 border-b border-primary/30 focus:border-accent focus:ring-0 px-0 py-2 text-primary transition-colors focus:outline-none resize-none"></textarea>
      </div>

      <button type="submit" class="self-start inline-flex items-center gap-2 text-accent hover:text-white transition-colors uppercase tracking-widest text-sm font-medium group mt-4">
        Envoyer la demande
        <span class="material-icons text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </button>
    </form>
  </div>
</section>