---
import { getEntry } from "astro:content";

const formulasEntry = await getEntry("formulas", "data");
const data = formulasEntry?.data || {};

const title = data.title || "Prestations";
const subtitle = data.subtitle || "Décoration & architecture d'intérieur";
const categories = data.categories || [];
const disclaimer =
  data.disclaimer ||
  "Tous les tarifs sont donnés à titre indicatif. Ils peuvent varier selon la surface (m2) du projet.";
---

<section class="w-full px-6 py-24 text-accent md:px-12 md:py-32">
  <div class="mx-auto max-w-[1920px]">
    {/* EN-TÊTE */}
    <div class="mb-20 flex flex-col items-center text-center">
      <h2 class="mb-6 font-display text-5xl leading-tight md:text-7xl">
        {title}
      </h2>
      <p
        class="max-w-xl text-sm font-light uppercase tracking-widest text-primary md:text-base"
      >
        {subtitle}
      </p>
    </div>

    {/* BOUCLE SUR LES CATÉGORIES (Particuliers puis Pros) */}
    {
      categories.map((category) => (
        <div class="mb-32 last:mb-0">
          {/* Titre de la catégorie */}
          <div class="mb-12 border-b border-black pb-4">
            <h3 class="font-display text-4xl text-primary-dark md:text-5xl">
              {category.name}
            </h3>
          </div>

          {/* Grille des Formules */}
          {category.packages && category.packages.length > 0 && (
            <div class="mb-16 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
              {category.packages.map((pkg) => (
                <div class="flex h-full flex-col rounded-lg border border-gray-100 bg-primary p-8 shadow-sm">
                  <h4 class="mb-2 font-display text-2xl">{pkg.name}</h4>
                  <span class="mb-8 block font-sans text-xs font-bold tracking-widest text-primary-dark">
                    {pkg.price}
                  </span>

                  {pkg.features && pkg.features.length > 0 && (
                    <ul class="mb-8 flex grow flex-col gap-4">
                      {pkg.features.map((feature) => (
                        <li class="flex items-start gap-3 text-sm font-light leading-relaxed text-gray-600">
                          <span class="material-symbols-outlined mt-[2px] text-sm text-accent">
                            check_circle
                          </span>
                          <span>{feature}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          )}

          {/* Section Options à la carte */}
          {category.options && category.options.length > 0 && (
            <div class="rounded-lg bg-primary-dark p-8 text-primary md:p-12">
              <h4 class="mb-8 font-display text-2xl text-accent">
                {category.optionsTitle || "Options supplémentaires"}
              </h4>
              <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                {category.options.map((opt) => (
                  <div class="flex items-center justify-between border-b border-white/20 pb-4">
                    <span class="pr-2 text-sm font-light text-white/80">
                      {opt.name}
                    </span>
                    <span class="whitespace-nowrap text-sm font-bold tracking-widest">
                      {opt.price}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      ))
    }

    {/* MENTIONS LÉGALES */}
    <div class="mx-auto mt-16 max-w-3xl text-center">
      <p class="text-xs font-light leading-relaxed text-primary">
        * {disclaimer}
      </p>
    </div>
  </div>
</section>
