---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

// 1. On récupère les projets et on garde seulement les 3 premiers
const allProjects = await getCollection("projects");
const previewProjects = allProjects
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<section class="mx-auto mb-24 w-full max-w-[1920px] px-4 md:mb-32 md:px-12">
  <div class="grid grid-cols-2 gap-2 md:grid-cols-4 md:gap-4">
    {
      previewProjects.map((project) => (
        <a
          href={`/projects/${project.slug}`}
          class="group relative block aspect-square overflow-hidden"
        >
          <Image
            src={project.data.image}
            alt={project.data.title}
            class="size-full object-cover transition-transform duration-1000 group-hover:scale-105"
            transition:name={`image-${project.slug}`}
          />

          <div class="absolute inset-0 flex items-center justify-center bg-background-dark/40 opacity-0 transition-opacity duration-500 group-hover:opacity-100">
            <span class="translate-y-4 font-display text-xl italic tracking-wide text-white transition-transform duration-500 group-hover:translate-y-0 lg:text-2xl">
              {project.data.title}
            </span>
          </div>
        </a>
      ))
    }

    <a
      href="/projects"
      class="group flex aspect-square flex-col items-center justify-center bg-accent-dark text-white transition-opacity hover:opacity-90 dark:bg-accent"
    >
      <span
        class="material-symbols-outlined mb-4 text-2xl font-light transition-transform duration-300 group-hover:translate-x-2 md:text-3xl"
        >arrow_forward</span
      >
      <span
        class="text-[10px] font-medium uppercase tracking-[0.2em] md:text-xs"
        >View More</span
      >
    </a>
  </div>
</section>
