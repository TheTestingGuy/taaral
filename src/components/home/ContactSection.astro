---

---

<section
  id="contact"
  class="mx-auto mb-24 w-full max-w-5xl border-t border-primary/20 px-4 pt-16 md:mb-32 md:pt-80"
>
  <div class="grid grid-cols-1 gap-16 md:grid-cols-2">
    <div>
      <h3 class="mb-6 font-display text-4xl text-primary md:text-6xl">
        Let's work<br />together.
      </h3>
      <p class="mb-8 max-w-md text-lg font-light opacity-80">
        Prêt à transformer votre espace ? Remplissez le formulaire ci-contre ou
        envoyez-nous un e-mail, nous vous répondrons dans les plus brefs délais.
      </p>
      <p class="mb-2 text-sm uppercase tracking-widest opacity-60">Email</p>
      <a
        href="mailto:taaralinterieur@gmail.com"
        class="font-display text-2xl transition-colors hover:text-accent"
        >taaralinterieur@gmail.com</a
      >
    </div>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="mt-4 flex flex-col gap-8 md:mt-0"
    >
      {
        /* 🚨 LE FIX EST ICI : Ce champ caché force Netlify à détecter le formulaire 🚨 */
      }
      <input type="hidden" name="form-name" value="contact" />
      {
        /* Champ caché anti-spam (Honeypot) : Netlify bloque les robots qui le remplissent */
      }
      <p class="hidden">
        <label
          >Ne pas remplir si vous êtes humain : <input
            name="bot-field"
          /></label
        >
      </p>

      <div class="flex flex-col gap-2">
        <label for="name" class="text-xs uppercase tracking-widest opacity-60"
          >Nom</label
        >
        <input
          type="text"
          id="name"
          name="name"
          required
          class="border-0 border-b border-primary/30 bg-transparent px-1 py-2 text-primary transition-colors focus:border-accent focus:outline-none focus:ring-0"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label for="email" class="text-xs uppercase tracking-widest opacity-60"
          >Adresse e-mail</label
        >
        <input
          type="email"
          id="email"
          name="email"
          required
          class="border-0 border-b border-primary/30 bg-transparent px-1 py-2 text-primary transition-colors focus:border-accent focus:outline-none focus:ring-0"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label
          for="message"
          class="text-xs uppercase tracking-widest opacity-60"
          >Détails du projet</label
        >
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          class="resize-none border-0 border-b border-primary/30 bg-transparent px-1 py-2 text-primary transition-colors focus:border-accent focus:outline-none focus:ring-0"
        ></textarea>
      </div>

      <button
        type="submit"
        class="group mt-4 inline-flex items-center gap-2 self-start text-sm font-medium uppercase tracking-widest text-accent transition-colors hover:text-white"
      >
        Envoyer la demande
        <span
          class="material-icons text-sm transition-transform group-hover:translate-x-1"
          >arrow_forward</span
        >
      </button>
    </form>
  </div>
</section>

<style is:global>
  /* Cible les champs pré-remplis par le navigateur (Chrome, Safari, Edge) */
  input:-webkit-autofill,
  input:-webkit-autofill:hover,
  input:-webkit-autofill:focus,
  textarea:-webkit-autofill,
  textarea:-webkit-autofill:hover,
  textarea:-webkit-autofill:focus {
    /* 1. On crée une ombre interne géante de la même couleur que ton fond bordeaux */
    -webkit-box-shadow: 0 0 0px 1000px #351419 inset !important;

    /* 2. On force le texte à rester blanc (ou la couleur que tu veux) */
    -webkit-text-fill-color: white !important;

    /* 3. On enlève le contour par défaut */
    transition: background-color 5000s ease-in-out 0s;
  }
</style>
