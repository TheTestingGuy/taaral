---

---

<section
  id="contact"
  class="mx-auto mb-24 w-full max-w-5xl border-t border-primary/20 pt-16 md:mb-32 md:pt-80"
>
  <div class="grid grid-cols-1 gap-16 md:grid-cols-2">
    <div>
      <h3 class="mb-6 font-display text-4xl text-primary md:text-6xl">
        Let's work<br />together.
      </h3>
      <p class="mb-8 max-w-md text-lg font-light opacity-80">
        Prêt à transformer votre espace ? Remplissez le formulaire ci-contre ou
        envoyez-nous un e-mail, nous vous répondrons dans les plus brefs délais.
      </p>
      <p class="mb-2 text-sm uppercase tracking-widest opacity-60">Email</p>
      <a
        href="mailto:hello@taaral.com"
        class="font-display text-2xl transition-colors hover:text-accent"
        >hello@taaral.com</a
      >
    </div>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="mt-4 flex flex-col gap-8 md:mt-0"
    >
      {
        /* Champ caché anti-spam (Honeypot) : Netlify bloque les robots qui le remplissent */
      }
      <p class="hidden">
        <label
          >Ne pas remplir si vous êtes humain : <input
            name="bot-field"
          /></label
        >
      </p>

      <div class="flex flex-col gap-2">
        <label for="name" class="text-xs uppercase tracking-widest opacity-60"
          >Nom</label
        >
        <input
          type="text"
          id="name"
          name="name"
          required
          class="border-0 border-b border-primary/30 bg-transparent px-0 py-2 text-primary transition-colors focus:border-accent focus:outline-none focus:ring-0"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label for="email" class="text-xs uppercase tracking-widest opacity-60"
          >Adresse e-mail</label
        >
        <input
          type="email"
          id="email"
          name="email"
          required
          class="border-0 border-b border-primary/30 bg-transparent px-0 py-2 text-primary transition-colors focus:border-accent focus:outline-none focus:ring-0"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label
          for="message"
          class="text-xs uppercase tracking-widest opacity-60"
          >Détails du projet</label
        >
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          class="resize-none border-0 border-b border-primary/30 bg-transparent px-0 py-2 text-primary transition-colors focus:border-accent focus:outline-none focus:ring-0"
        ></textarea>
      </div>

      <button
        type="submit"
        class="group mt-4 inline-flex items-center gap-2 self-start text-sm font-medium uppercase tracking-widest text-accent transition-colors hover:text-white"
      >
        Envoyer la demande
        <span
          class="material-icons text-sm transition-transform group-hover:translate-x-1"
          >arrow_forward</span
        >
      </button>
    </form>
  </div>
</section>
