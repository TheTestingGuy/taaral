---
import { Image } from "astro:assets";
import { getEntry } from "astro:content";

const projectsEntry = await getEntry("projects-page", "data");
const headline = projectsEntry?.data.headline || "We are on a mission...";

const videoPath = projectsEntry?.data.backgroundVideo;
---

<section
  data-bg="bg-secondary-dark"
  class="flex w-full flex-col items-center bg-transparent px-4 pb-24 text-white md:px-12"
>
  <div class="mx-auto w-full max-w-[1400px]">
    <div
      class="group relative mb-16 aspect-[16/9] w-full overflow-hidden shadow-2xl md:mb-24 md:aspect-[21/9]"
    >
      {
        videoPath && projectsEntry?.data.backgroundImage ? (
          <video
            src={videoPath}
            poster={projectsEntry.data.backgroundImage.src}
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            class="absolute inset-0 size-full object-cover opacity-80"
          />
        ) : projectsEntry?.data.backgroundImage ? (
          <Image
            src={projectsEntry.data.backgroundImage}
            alt="Hero image"
            class="absolute inset-0 size-full object-cover transition-transform duration-1000 ease-out group-hover:scale-105"
            loading="eager"
            fetchpriority="high"
          />
        ) : null
      }
    </div>
    <div class="mx-auto w-full max-w-4xl text-center md:text-left">
      <h2
        class="font-serif text-3xl leading-tight text-accent md:text-5xl lg:text-6xl"
      >
        {headline}
      </h2>
    </div>
  </div>
</section>
